ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
TRANSCRIBE_PROVIDER=openai
OPENAI_API_KEY=
ADMIN_USERNAME=
ADMIN_PASSWORD=
SESSION_SECRET=
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_STORE_DOMAIN=
# Public URL this app is reachable at (e.g. https://your-app.up.railway.app),
# no trailing slash. Required for the Shopify OAuth install flow on
# platforms like Railway/Render, where the reverse proxy can make Next.js
# see an internal Host header (localhost:PORT) instead of the real public
# domain, sending Shopify the wrong redirect_uri. Not needed for plain
# `npm run dev` on localhost.
APP_URL=
# FastMoss Open API (developers.fastmoss.com) — powers the Trend Analysis
# "Update" button. Sign up, generate a key in the console, paste it here.
FASTMOSS_API_KEY=
# Optional. Narrows video/v1/search server-side to one product category
# (cheaper + more precise than the keyword-sweep fallback used when this is
# blank). Look yours up at /api/trends/fastmoss-categories once the key above
# is set.
FASTMOSS_PET_CATEGORY_ID=
# Optional, defaults to US.
FASTMOSS_REGION=
